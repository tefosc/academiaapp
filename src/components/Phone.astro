---
// Marco de teléfono estático con una captura real, optimizada por astro:assets.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  size?: 'sm' | 'md' | 'lg';
  loading?: 'eager' | 'lazy';
}
const { src, alt, size = 'md', loading = 'lazy' } = Astro.props;
const sizeClass = size === 'md' ? '' : size;
---

<div class:list={['device', sizeClass]}>
  <div class="device-screen">
    <Image src={src} alt={alt} width={600} format="webp" quality={70} loading={loading} />
  </div>
</div>
