---
// "Video" del hero: carrusel con crossfade de capturas reales (optimizadas a WebP).
import { Image } from "astro:assets";
import screenHome from "../assets/screens/screen-home.png";
import screenSimulacro from "../assets/screens/screen-simulacro.png";
import screenResultados from "../assets/screens/screen-resultados.png";
import screenProgresoMarkov from "../assets/screens/screen-progreso-markov.png";
import screenMatchCarrera from "../assets/screens/screen-match-carrera.png";

const screens = [
  {
    src: screenHome,
    alt: "Pantalla de inicio con progreso y recomendación adaptativa",
  },
  {
    src: screenSimulacro,
    alt: "Simulacro con preguntas reales del examen de admisión UNC",
  },
  {
    src: screenResultados,
    alt: "Resultados del simulacro con diagnóstico por temas",
  },
  {
    src: screenProgresoMarkov,
    alt: "Mapa de dominio Markov con fortalezas y puntos críticos",
  },
  { src: screenMatchCarrera, alt: "Tu mejor match de carrera en la UNC" },
];
---

<div class="device demo">
  <div class="device-screen">
    {
      screens.map((s, i) => (
        <Image
          class:list={["slide", { active: i === 0 }]}
          src={s.src}
          alt={s.alt}
          width={600}
          format="webp"
          quality={70}
          loading={i === 0 ? "eager" : "lazy"}
          fetchpriority={i === 0 ? "high" : "low"}
        />
      ))
    }
  </div>
</div>

<style>
  .slide {
    opacity: 0;
    transform: scale(1.04);
    transition:
      opacity 0.7s ease,
      transform 6s ease-out;
  }
  .slide.active {
    opacity: 1;
    transform: scale(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .slide {
      transition: opacity 0.3s ease;
      transform: none;
    }
    .slide.active {
      transform: none;
    }
  }
</style>

<script>
  (function () {
    const slides = Array.from(
      document.querySelectorAll<HTMLImageElement>(".demo .slide"),
    );
    if (slides.length < 2) return;

    const reduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    let i = 0;

    function next() {
      slides[i].classList.remove("active");
      i = (i + 1) % slides.length;
      slides[i].classList.add("active");
    }

    setInterval(next, reduced ? 4200 : 3400);
  })();
</script>
