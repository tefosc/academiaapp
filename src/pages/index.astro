---
import Layout from '../layouts/Layout.astro';
import PhoneDemo from '../components/PhoneDemo.astro';
import Phone from '../components/Phone.astro';

import image1 from '../assets/screens/image1.png';
import image2 from '../assets/screens/image2.png';
import image3 from '../assets/screens/image3.png';
import image4 from '../assets/screens/image4.png';
import image6 from '../assets/screens/image6.png';
import image10 from '../assets/screens/image10.png';
import image13 from '../assets/screens/image13.png';
---

<Layout>
  <!-- NAVBAR -->
  <header class="navbar">
    <div class="nav-inner">
      <a href="/" class="brand">
        <span class="brand-icon">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none">
            <circle cx="5" cy="19" r="2" fill="#fff" />
            <circle cx="19" cy="5" r="2.6" fill="#F5A623" />
            <line x1="6" y1="18" x2="17" y2="7" stroke="#fff" stroke-width="1.6" />
          </svg>
        </span>
        <span class="brand-name">AcademIA</span>
      </a>

      <nav class="nav-links">
        <a href="#how">Cómo funciona</a>
        <a href="#showcase">La app</a>
      </nav>

      <a href="#download" class="btn-pill">Descargar</a>
    </div>
  </header>

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="hero-bg" aria-hidden="true"></div>

      <div class="hero-inner">
        <div class="hero-copy">
          <span class="eyebrow">
            <span class="eyebrow-dot"></span>
            Preparación admisión · UNC Cajamarca
          </span>

          <h1>Tu camino al ingreso,<br /><em>trazado por IA.</em></h1>

          <p class="lead">
            Practica con exámenes reales de admisión a la UNC, recibe un plan que
            se ajusta a ti después de cada simulacro y descubre, en cinco
            preguntas, qué tan cerca estás de tu carrera.
          </p>

          <div class="cta-row">
            <a href="#download" class="btn-primary">Descargar gratis</a>
            <a href="#how" class="btn-text">Ver cómo funciona →</a>
          </div>

          <ul class="hero-stats">
            <li><b>90</b> preguntas por examen</li>
            <li><b>30</b> exámenes oficiales</li>
            <li><b>28</b> carreras mapeadas</li>
          </ul>
        </div>

        <div class="hero-stage">
          <div class="hero-phone-back" aria-hidden="true">
            <Phone src={image10} alt="" size="sm" />
          </div>

          <div class="hero-phone-front">
            <PhoneDemo />
            <span class="float-chip chip-top">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#15A98C" stroke-width="2.4"><circle cx="12" cy="12" r="9" /><path d="M9 12l2 2 4-4" /></svg>
              Exámenes reales UNC
            </span>
            <span class="float-chip chip-bottom">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.4"><path d="M12 2l2.6 6.6L21 11l-6.4 2.4L12 20l-2.6-6.6L3 11l6.4-2.4z" /></svg>
              Match de carrera
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- PRUEBA / CONFIANZA -->
    <section class="trust">
      <ul class="trust-list">
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.4"><path d="M20 6 9 17l-5-5" /></svg>
          Diseñada para postulantes de la <strong>UNC Cajamarca</strong>
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.4"><path d="M20 6 9 17l-5-5" /></svg>
          Basada en <strong>exámenes oficiales 2023–2026</strong>
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.4"><path d="M20 6 9 17l-5-5" /></svg>
          Un <strong>plan de estudio</strong> que se ajusta a ti
        </li>
      </ul>
    </section>

    <!-- FEATURES (filas alternadas) -->
    <section class="features" id="features">
      <div class="section-head">
        <span class="kicker">Por qué AcademIA</span>
        <h2>No es una app de práctica más.</h2>
        <p>Cada parte está pensada para cómo funciona realmente el ingreso a la UNC.</p>
      </div>

      <!-- fila 1 -->
      <div class="feature-row">
        <div class="feature-text">
          <span class="feature-num">01</span>
          <h3>Simulacros reales de la UNC</h3>
          <p>
            Resuelve exámenes de admisión tal como son: 90 preguntas, módulos A
            a E, períodos reales. El mismo formato, la misma estructura y la
            misma dificultad que vas a enfrentar el día del examen.
          </p>
          <ul class="ticks">
            <li>Preguntas extraídas de exámenes oficiales</li>
            <li>Cronómetro y puntaje como en la prueba real</li>
            <li>Revisa cada examen pregunta por pregunta</li>
          </ul>
        </div>
        <div class="feature-media">
          <div class="media-phone">
            <Phone src={image2} alt="Pregunta de simulacro de razonamiento matemático" />
          </div>
          <div class="callout callout-a">
            <span class="callout-label">Examen UNC 2026-I</span>
            <span class="callout-value">90 preguntas · 180 min</span>
          </div>
        </div>
      </div>

      <!-- fila 2 -->
      <div class="feature-row reverse">
        <div class="feature-text">
          <span class="feature-num">02</span>
          <h3>Un plan que aprende de ti</h3>
          <p>
            AcademIA detecta tus temas débiles y arma tu plan de la semana: qué
            estudiar, cuántas preguntas y por qué. No es un temario fijo —
            cambia a medida que avanzas y según los días que faltan.
          </p>
          <ul class="ticks">
            <li>Identifica tus puntos críticos automáticamente</li>
            <li>Agenda semanal con prioridades por tema</li>
            <li>Recomendaciones después de cada simulacro</li>
          </ul>
          <p class="method-note">
            Metodología: un sistema adaptativo basado en cadenas de Markov.
          </p>
        </div>
        <div class="feature-media">
          <div class="media-phone">
            <Phone src={image3} alt="Resultados del simulacro con plan de estudio" />
          </div>
          <div class="callout callout-b">
            <span class="callout-label">Agenda de esta semana</span>
            <span class="callout-value">Álgebra · 15 preguntas hoy</span>
          </div>
        </div>
      </div>

      <!-- fila 3 -->
      <div class="feature-row">
        <div class="feature-text">
          <span class="feature-num">03</span>
          <h3>Tu carrera, con datos</h3>
          <p>
            Responde cinco preguntas sobre tus intereses y obtén tu porcentaje
            de afinidad con cada una de las 28 carreras de la UNC. Explora cada
            una a fondo y decide con información, no con corazonadas.
          </p>
          <ul class="ticks">
            <li>Test de afinidad en cinco preguntas</li>
            <li>Ranking de carreras más afines a ti</li>
            <li>Descripción, salidas y temas clave de cada carrera</li>
          </ul>
        </div>
        <div class="feature-media">
          <div class="media-phone">
            <Phone src={image6} alt="Resultado del test de afinidad de carrera" />
          </div>
          <div class="callout callout-c">
            <span class="callout-label">Tu mejor match</span>
            <span class="callout-value">Ing. Hidráulica · 67% afín</span>
          </div>
        </div>
      </div>
    </section>

    <!-- SHOWCASE (3 bloques narrativos) -->
    <section class="showcase" id="showcase">
      <div class="section-head section-head--center">
        <span class="kicker kicker--light">Una sola app</span>
        <h2>Todo tu proceso, en un mismo lugar.</h2>
        <p>De la práctica diaria a la elección de carrera, en tres pasos.</p>
      </div>

      <div class="story">
        <article class="story-block">
          <div class="story-phone"><Phone src={image13} alt="Práctica diaria por categorías" /></div>
          <h3><span class="story-step">1</span> Practica</h3>
          <p>Sesiones diarias por área o práctica adaptativa que refuerza tus temas más débiles.</p>
        </article>

        <article class="story-block">
          <div class="story-phone"><Phone src={image4} alt="Resultados y agenda semanal" /></div>
          <h3><span class="story-step">2</span> Revisa tus resultados</h3>
          <p>Tu puntaje, tu progreso y la agenda de la semana, actualizados después de cada simulacro.</p>
        </article>

        <article class="story-block">
          <div class="story-phone"><Phone src={image10} alt="Catálogo de carreras de la UNC" /></div>
          <h3><span class="story-step">3</span> Elige tu carrera</h3>
          <p>Explora las 28 carreras de la UNC con su descripción, salidas laborales y temas clave.</p>
        </article>
      </div>
    </section>

    <!-- CÓMO FUNCIONA -->
    <section class="how" id="how">
      <div class="section-head">
        <span class="kicker">El proceso</span>
        <h2>Tres pasos que se retroalimentan.</h2>
      </div>

      <div class="steps">
        <article class="step">
          <span class="step-dot">1</span>
          <h3>Practica</h3>
          <p>Resuelve simulacros completos o sesiones cortas por área. Cada respuesta alimenta tu perfil.</p>
        </article>
        <article class="step">
          <span class="step-dot">2</span>
          <h3>El sistema aprende</h3>
          <p>La app identifica tus áreas críticas y actualiza tu probabilidad de ingreso a cada carrera.</p>
        </article>
        <article class="step">
          <span class="step-dot">3</span>
          <h3>Recibe tu plan</h3>
          <p>AcademIA te dice qué estudiar mañana, con qué prioridad y por cuánto tiempo. Y vuelves a empezar.</p>
        </article>
      </div>
    </section>

    <!-- DESCARGA -->
    <section class="download" id="download">
      <div class="download-card">
        <div class="download-copy">
          <span class="kicker kicker--light">Lanzamiento próximo</span>
          <h2>Prepárate para el ingreso.</h2>
          <p>AcademIA estará disponible muy pronto. Estas son las tiendas donde podrás descargarla.</p>
          <div class="badges">
            <a href="#" class="badge" aria-label="Próximamente en App Store">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M16.4 12.7c0-2 1.6-3 1.7-3a3.7 3.7 0 0 0-2.9-1.6c-1.2-.1-2.4.7-3 .7s-1.6-.7-2.6-.7a3.9 3.9 0 0 0-3.3 2c-1.4 2.5-.4 6.2 1 8.2.7 1 1.5 2.1 2.5 2 1-.04 1.4-.65 2.6-.65s1.6.65 2.6.63c1.1-.02 1.8-1 2.4-2a9 9 0 0 0 1.1-2.2c-.02-.01-2.1-.82-2.1-3.18zM14.5 6.3a3.5 3.5 0 0 0 .8-2.5 3.6 3.6 0 0 0-2.3 1.2 3.3 3.3 0 0 0-.8 2.4 3 3 0 0 0 2.3-1.1z" /></svg>
              <span><small>Próximamente en</small><strong>App Store</strong></span>
            </a>
            <a href="#" class="badge" aria-label="Próximamente en Google Play">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M4 3.5 13.5 12 4 20.5c-.3-.2-.5-.6-.5-1V4.5c0-.4.2-.8.5-1zm10.8 9.2 2.6 2.4-9.2 5.2 6.6-7.6zm0-1.4L8.2 3.7l9.2 5.2-2.6 2.4zM17.9 9.7l2.6 1.5c.5.3.5 1.3 0 1.6l-2.6 1.5-2.8-2.3 2.8-2.3z" /></svg>
              <span><small>Próximamente en</small><strong>Google Play</strong></span>
            </a>
          </div>
        </div>
        <div class="download-phone" aria-hidden="true">
          <Phone src={image1} alt="" size="sm" />
        </div>
      </div>
    </section>
  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="brand-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
            <circle cx="5" cy="19" r="2" fill="#fff" />
            <circle cx="19" cy="5" r="2.6" fill="#F5A623" />
            <line x1="6" y1="18" x2="17" y2="7" stroke="#fff" stroke-width="1.6" />
          </svg>
        </span>
        <span>AcademIA</span>
      </div>
      <nav class="footer-links">
        <a href="/privacy-policy">Política de privacidad</a>
        <a href="/terms-of-use">Términos de uso</a>
        <a href="/delete-account">Eliminar cuenta</a>
      </nav>
      <p class="footer-copy">&copy; AcademIA 2026 · Preparación admisión UNC, Cajamarca, Perú</p>
    </div>
  </footer>
</Layout>

<style>
  /* ============ NAVBAR ============ */
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(247, 246, 243, 0.8);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(231, 228, 222, 0.7);
  }
  .nav-inner {
    max-width: 1140px;
    margin: 0 auto;
    height: 66px;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 9px;
    font-weight: 800;
    font-size: 17px;
    color: var(--navy-deep);
    letter-spacing: -0.01em;
  }
  .brand-icon {
    width: 32px;
    height: 32px;
    border-radius: 9px;
    background: linear-gradient(145deg, var(--navy), var(--navy-deep));
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }
  .nav-links {
    display: flex;
    gap: 28px;
    margin: 0 auto;
  }
  .nav-links a {
    position: relative;
    font-size: 14.5px;
    font-weight: 600;
    color: var(--muted);
    transition: color 0.16s ease;
  }
  .nav-links a:hover { color: var(--navy-deep); }
  .nav-links a.active { color: var(--navy-deep); }
  .nav-links a.active::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -7px;
    height: 2px;
    background: var(--gold);
    border-radius: 2px;
  }
  .btn-pill {
    background: var(--navy);
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    padding: 10px 20px;
    border-radius: 999px;
    box-shadow: 0 6px 16px -8px var(--shadow);
    transition: transform 0.16s ease, box-shadow 0.16s ease;
  }
  .btn-pill:hover { transform: translateY(-1px); box-shadow: 0 10px 20px -8px var(--shadow); }
  @media (max-width: 720px) {
    .nav-links { display: none; }
    .btn-pill { margin-left: auto; }
  }

  /* ============ HERO ============ */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 72px 24px 96px;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(60% 55% at 12% 8%, rgba(27, 61, 110, 0.16), transparent 70%),
      radial-gradient(45% 45% at 92% 18%, rgba(245, 166, 35, 0.14), transparent 70%),
      radial-gradient(55% 60% at 78% 100%, rgba(21, 169, 140, 0.12), transparent 70%);
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1140px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.02fr 0.98fr;
    gap: 48px;
    align-items: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--navy);
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid var(--border);
    padding: 7px 14px;
    border-radius: 999px;
    margin-bottom: 24px;
  }
  .eyebrow-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 0 4px rgba(245, 166, 35, 0.18);
  }
  h1 {
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1.04;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--navy-deep);
  }
  h1 em {
    font-style: normal;
    color: var(--teal);
    position: relative;
  }
  h1 em::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: 0.04em;
    height: 0.42em;
    background: rgba(21, 169, 140, 0.14);
    border-radius: 4px;
    z-index: -1;
  }
  .lead {
    margin-top: 22px;
    font-size: 17.5px;
    line-height: 1.6;
    color: var(--muted);
    max-width: 480px;
  }
  .cta-row {
    margin-top: 32px;
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--navy);
    color: #fff;
    font-size: 15.5px;
    font-weight: 700;
    padding: 15px 26px;
    border-radius: 14px;
    box-shadow: 0 14px 30px -12px var(--shadow);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 18px 36px -12px var(--shadow); }
  .btn-text {
    font-size: 15px;
    font-weight: 700;
    color: var(--navy-deep);
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition: border-color 0.18s ease;
  }
  .btn-text:hover { border-color: var(--navy-deep); }

  .hero-stats {
    list-style: none;
    margin-top: 44px;
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
  }
  .hero-stats li {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.3;
    max-width: 90px;
  }
  .hero-stats b {
    display: block;
    font-size: 24px;
    font-weight: 800;
    color: var(--navy-deep);
    letter-spacing: -0.02em;
  }

  /* hero stage con dos teléfonos */
  .hero-stage {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 580px;
  }
  .hero-phone-front {
    position: relative;
    z-index: 2;
    transform: rotate(-2deg);
  }
  .hero-phone-back {
    position: absolute;
    z-index: 1;
    right: 4%;
    top: 8%;
    transform: rotate(8deg);
    opacity: 0.85;
    filter: saturate(1.05);
  }
  .float-chip {
    position: absolute;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 9px 13px;
    font-size: 12.5px;
    font-weight: 700;
    color: var(--navy-deep);
    box-shadow: 0 16px 32px -16px var(--shadow);
    animation: bob 5s ease-in-out infinite;
  }
  .chip-top { top: 9%; left: -14%; }
  .chip-bottom { bottom: 12%; right: -12%; animation-delay: 1.6s; }
  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-9px); }
  }

  @media (max-width: 900px) {
    .hero { padding: 40px 24px 72px; }
    .hero-inner { grid-template-columns: 1fr; gap: 24px; text-align: center; }
    .hero-copy { order: 1; }
    .hero-stage { order: 2; min-height: 0; }
    .lead { margin-left: auto; margin-right: auto; }
    .cta-row, .hero-stats { justify-content: center; }
    .hero-stats { margin-top: 32px; }
    .hero-stats li { text-align: center; }
  }
  @media (max-width: 560px) {
    .float-chip { display: none; }
    .hero-phone-back { right: -2%; opacity: 0.7; }
  }

  /* ============ TRUST ============ */
  .trust {
    background: var(--navy-deep);
    color: rgba(255, 255, 255, 0.85);
    padding: 20px 24px;
  }
  .trust-list {
    list-style: none;
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px 36px;
  }
  .trust-list li {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 14px;
  }
  .trust-list strong { color: #fff; font-weight: 700; }

  /* ============ SECTION HEADS ============ */
  .section-head { max-width: 1140px; margin: 0 auto 56px; }
  .section-head--center { text-align: center; }
  .section-head--center p { margin-left: auto; margin-right: auto; }
  .kicker {
    display: inline-block;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 14px;
  }
  .kicker--light { color: var(--gold); }
  h2 {
    font-size: clamp(27px, 3.4vw, 40px);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--navy-deep);
    line-height: 1.1;
  }
  .section-head > p {
    margin-top: 14px;
    font-size: 17px;
    color: var(--muted);
    max-width: 520px;
  }

  /* ============ FEATURES ============ */
  .features {
    padding: 96px 24px;
    background: #fff;
    border-top: 1px solid var(--border);
  }
  .feature-row {
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
    padding: 40px 0;
  }
  .feature-row.reverse .feature-text { order: 2; }
  .feature-row.reverse .feature-media { order: 1; }

  .feature-num {
    display: inline-block;
    font-size: 14px;
    font-weight: 800;
    color: var(--gold);
    letter-spacing: 0.1em;
    margin-bottom: 14px;
  }
  .feature-text h3 {
    font-size: clamp(22px, 2.6vw, 30px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--navy-deep);
    margin-bottom: 14px;
    line-height: 1.15;
  }
  .feature-text > p {
    font-size: 16px;
    line-height: 1.65;
