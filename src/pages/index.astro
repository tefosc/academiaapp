---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div style="overflow-x:hidden;background:#0b1220">

    <!-- NAV -->
    <nav id="navbar">
      <div class="nav-inner">
        <div class="nav-brand">
          <img src="/academia-logo.svg" alt="AcademIA" width="40" height="40" class="nav-logo" />
          <span class="nav-wordmark">Academ<span class="nav-ia">IA</span></span>
        </div>
        <div class="nav-right">
          <div class="nav-links" id="nav-links">
            <a href="#como">Cómo funciona</a>
            <a href="#features">Features</a>
            <a href="#modulos">Módulos UNC</a>
          </div>
          <a href="#descargar" class="nav-cta">Descargar</a>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <header class="hero">
      <svg aria-hidden="true" preserveAspectRatio="xMidYMid slice" viewBox="0 0 1240 640" class="hero-svg">
        <path d="M-60 590 C 320 548 540 384 780 314 S 1150 162 1330 92" style="fill:none;stroke:#4A90D9;stroke-opacity:.45;stroke-width:2.2;stroke-linecap:round;stroke-dasharray:2 10"></path>
        <path d="M-60 622 C 340 560 600 436 820 340 S 1150 210 1330 128" style="fill:none;stroke:#ffffff;stroke-opacity:.12;stroke-width:1.6;stroke-linecap:round"></path>
        <path d="M-60 372 C 260 300 540 250 900 212 S 1190 150 1330 150" style="fill:none;stroke:#4A90D9;stroke-opacity:.18;stroke-width:1.3;stroke-linecap:round;stroke-dasharray:2 12"></path>
        <g transform="translate(910 322)">
          <circle r="238" style="fill:none;stroke:#ffffff;stroke-opacity:.05;stroke-width:1"></circle>
          <circle r="182" style="fill:none;stroke:#4A90D9;stroke-opacity:.16;stroke-width:.9;stroke-dasharray:3 5"></circle>
          <circle r="128" style="fill:none;stroke:#ffffff;stroke-opacity:.08;stroke-width:1"></circle>
          <circle r="78" style="fill:none;stroke:#4A90D9;stroke-opacity:.55;stroke-width:2.2"></circle>
        </g>
        <circle cx="60" cy="566" r="11" style="fill:#142040;stroke:#4A90D9;stroke-opacity:.6;stroke-width:2"></circle>
        <circle cx="60" cy="566" r="5.5" style="fill:#4A90D9"></circle>
        <circle cx="1252" cy="118" r="13" style="fill:#C9A800"></circle>
      </svg>

      <div class="hero-inner">
        <div class="hero-copy">
          <div class="hero-label">
            <span class="hero-dot hero-dot--blue"></span>
            <span class="hero-dash"></span>
            <span class="hero-dot hero-dot--gold"></span>
            <span class="hero-label-text">Universidad Nacional de Cajamarca</span>
          </div>
          <h1>Tu ingreso a la UNC, <span class="h1-gold">calculado en tiempo real.</span></h1>
          <p class="hero-lead">AcademIA mide tu <strong>afinidad</strong> por cada carrera mientras practicas. Un sistema de Cadenas de Markov aprende de cada respuesta y te dice qué estudiar hoy.</p>
          <div id="descargar" class="store-row">
            <a href="https://play.google.com/store/apps" class="store-btn store-btn--light">
              <i class="mdi mdi-google-play store-icon"></i>
              <span class="store-text">
                <small>Disponible en</small>
                <strong>Google Play</strong>
              </span>
            </a>
            <a href="https://www.apple.com/app-store/" class="store-btn store-btn--outline">
              <i class="mdi mdi-apple store-icon"></i>
              <span class="store-text">
                <small>Descarga en</small>
                <strong>App Store</strong>
              </span>
            </a>
          </div>
          <p class="hero-footnote">Gratis para empezar · iOS y Android</p>
        </div>

        <div class="hero-phone-slot">
          <div class="phone-wrap">
            <div class="phone-frame">
              <div class="phone-notch"></div>
              <div class="phone-screen">
                <img src="/afinidad-screen.webp" alt="Pantalla de afinidad por carrera de AcademIA" />
              </div>
            </div>
            <div class="phone-callout">
              <div class="callout-icon">
                <i class="mdi mdi-trending-up" style="font-size:23px;color:#22c55e"></i>
              </div>
              <div class="callout-body">
                <span class="callout-label">Afinidad · Contabilidad</span>
                <span class="callout-value"><span style="color:#22c55e">▲ +23%</span> <span class="callout-sub">esta semana</span></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- PROBLEMA -->
    <section class="problema">
      <div class="section-inner problema-inner">
        <span class="kicker kicker--red">El problema</span>
        <h2>Estudias a ciegas y nadie te dice si vas bien.</h2>
        <div class="problema-grid">
          <div class="problema-card">
            <i class="mdi mdi-help-circle-outline problema-icon"></i>
            <p>No sabes en qué temas enfocarte ni cuáles te están restando.</p>
          </div>
          <div class="problema-card">
            <i class="mdi mdi-progress-question problema-icon"></i>
            <p>No sabes si ya estás listo para el examen o cuánto te falta.</p>
          </div>
          <div class="problema-card">
            <i class="mdi mdi-map-marker-question-outline problema-icon"></i>
            <p>Nadie te dice qué tan cerca estás de la carrera que quieres.</p>
          </div>
        </div>
        <p class="problema-cta">AcademIA cambia eso <span class="teal">desde la primera pregunta</span> que respondes.</p>
      </div>
    </section>

    <!-- CÓMO FUNCIONA -->
    <section id="como" class="como">
      <div class="section-inner">
        <div class="section-head section-head--center">
          <span class="kicker kicker--teal">Cómo funciona</span>
          <h2>Practicas. El sistema aprende. Tú ves el avance.</h2>
        </div>
        <div class="como-grid">
          <div class="como-card">
            <span class="step-num">01</span>
            <h3>Practica</h3>
            <p>Resuelve simulacros y preguntas por tema, igual que en el examen real de la UNC.</p>
          </div>
          <div class="como-card">
            <span class="step-num">02</span>
            <h3>El sistema analiza</h3>
            <p>Cada respuesta alimenta un modelo de Cadenas de Markov que entiende tu nivel real.</p>
          </div>
          <div class="como-card">
            <span class="step-num">03</span>
            <h3>Tu afinidad se actualiza</h3>
            <p>Ves en vivo qué tan probable es tu ingreso a cada carrera de la UNC.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section id="features" class="features">
      <div class="section-inner">
        <div class="section-head">
          <span class="kicker kicker--teal">Lo que hace AcademIA</span>
          <h2>Todo lo que necesitas para llegar listo.</h2>
        </div>
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon" style="background:rgba(13,148,136,.16)">
              <i class="mdi mdi-speedometer" style="color:#2dd4bf"></i>
            </div>
            <h3>Afinidad por carrera en vivo</h3>
            <p>Un medidor animado muestra tu probabilidad de ingreso y se mueve con cada respuesta.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon" style="background:rgba(30,58,138,.28)">
              <i class="mdi mdi-clipboard-text-clock-outline" style="color:#93b4f5"></i>
            </div>
            <h3>Simulacros reales UNC</h3>
            <p>90 preguntas, 3 horas. Exactamente como el examen oficial de admisión.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon" style="background:rgba(245,158,11,.16)">
              <i class="mdi mdi-bullseye-arrow" style="color:#f59e0b"></i>
            </div>
            <h3>Práctica por tema</h3>
            <p>Enfócate justo donde más necesitas mejorar, tema por tema.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon" style="background:rgba(13,148,136,.16)">
              <i class="mdi mdi-clipboard-list-outline" style="color:#2dd4bf"></i>
            </div>
            <h3>Plan personalizado</h3>
            <p>El sistema te dice qué estudiar hoy según tu nivel y tu meta de carrera.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon" style="background:rgba(245,158,11,.16)">
              <i class="mdi mdi-calendar-clock" style="color:#f59e0b"></i>
            </div>
            <h3>Cuenta regresiva al examen</h3>
            <p>Ingresa tu fecha y la app lleva la cuenta de los días que te quedan.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- GAUGE FEATURE ESTRELLA -->
    <section class="gauge-section">
      <div class="gauge-bg-rings" aria-hidden="true">
        <svg viewBox="0 0 400 400">
          <circle cx="200" cy="200" r="190" style="fill:none;stroke:rgba(255,255,255,.04);stroke-width:1"></circle>
          <circle cx="200" cy="200" r="140" style="fill:none;stroke:rgba(255,255,255,.04);stroke-width:1"></circle>
          <circle cx="200" cy="200" r="190" style="fill:none;stroke:rgba(245,158,11,.22);stroke-width:1.5;stroke-dasharray:2 10;stroke-linecap:round"></circle>
        </svg>
      </div>
      <div class="section-inner gauge-inner">
        <span class="kicker kicker--gold">El feature estrella</span>
        <h2 class="gauge-h2">Cada respuesta que das mueve el indicador.</h2>
        <p class="gauge-lead">La afinidad va de crítico a sólido. <strong>Tú decides cómo termina.</strong></p>

        <div class="gauge-grid" id="gauge-grid">
          <div class="gauge-card">
            <div class="gauge-ring-wrap">
              <svg viewBox="0 0 200 200" class="gauge-svg">
                <circle cx="100" cy="100" r="80" style="fill:none;stroke:rgba(255,255,255,.07);stroke-width:13"></circle>
                <circle cx="100" cy="100" r="80" transform="rotate(-90 100 100)"
                  class="gauge-arc"
                  data-pct="34"
                  data-color="#dc2626"
                  style="fill:none;stroke-linecap:round;stroke-width:13;stroke-dasharray:502.65;stroke:#dc2626;stroke-dashoffset:502.65"></circle>
              </svg>
              <div class="gauge-center">
                <span class="gauge-pct">34<span class="gauge-unit">%</span></span>
                <span class="gauge-state" style="color:#dc2626">Crítico</span>
              </div>
            </div>
            <span class="gauge-career">Enfermería</span>
            <span class="gauge-sub">Afinidad UNC</span>
          </div>
          <div class="gauge-card">
            <div class="gauge-ring-wrap">
              <svg viewBox="0 0 200 200" class="gauge-svg">
                <circle cx="100" cy="100" r="80" style="fill:none;stroke:rgba(255,255,255,.07);stroke-width:13"></circle>
                <circle cx="100" cy="100" r="80" transform="rotate(-90 100 100)"
                  class="gauge-arc"
                  data-pct="61"
                  data-color="#f59e0b"
                  style="fill:none;stroke-linecap:round;stroke-width:13;stroke-dasharray:502.65;stroke:#f59e0b;stroke-dashoffset:502.65"></circle>
              </svg>
              <div class="gauge-center">
                <span class="gauge-pct">61<span class="gauge-unit">%</span></span>
                <span class="gauge-state" style="color:#f59e0b">En progreso</span>
              </div>
            </div>
            <span class="gauge-career">Ingeniería Civil</span>
            <span class="gauge-sub">Afinidad UNC</span>
          </div>
          <div class="gauge-card">
            <div class="gauge-ring-wrap">
              <svg viewBox="0 0 200 200" class="gauge-svg">
                <circle cx="100" cy="100" r="80" style="fill:none;stroke:rgba(255,255,255,.07);stroke-width:13"></circle>
                <circle cx="100" cy="100" r="80" transform="rotate(-90 100 100)"
                  class="gauge-arc"
                  data-pct="88"
                  data-color="#16a34a"
                  style="fill:none;stroke-linecap:round;stroke-width:13;stroke-dasharray:502.65;stroke:#16a34a;stroke-dashoffset:502.65"></circle>
              </svg>
              <div class="gauge-center">
                <span class="gauge-pct">88<span class="gauge-unit">%</span></span>
                <span class="gauge-state" style="color:#16a34a">Sólido</span>
              </div>
            </div>
            <span class="gauge-career">Ingeniería de Sistemas</span>
            <span class="gauge-sub">Afinidad UNC</span>
          </div>
        </div>

        <div class="gauge-legend">
          <span class="legend-item"><span class="legend-dot" style="background:#dc2626"></span>Crítico</span>
          <span class="legend-item"><span class="legend-dot" style="background:#f59e0b"></span>En progreso</span>
          <span class="legend-item"><span class="legend-dot" style="background:#16a34a"></span>Sólido</span>
        </div>
      </div>
    </section>

    <!-- MÓDULOS UNC -->
    <section id="modulos" class="modulos">
      <div class="section-inner">
        <div class="section-head">
          <span class="kicker kicker--teal">Cobertura completa</span>
          <h2>Los 5 módulos del examen de admisión.</h2>
          <p>AcademIA cubre cada módulo de la UNC con simulacros y práctica adaptada a sus carreras.</p>
        </div>
        <div class="modulos-table">
          <div class="modulo-row">
            <div class="modulo-icono" style="background:rgba(21,101,192,.16);color:#1565C0">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="26" height="26" fill="none" aria-hidden="true"><path d="M436.67 184.11a27.17 27.17 0 0 1-38.3 0l-22.48-22.49a27.15 27.15 0 0 1 0-38.29l50.89-50.89a.85.85 0 0 0-.26-1.38C393.68 57 351.09 64.15 324.05 91c-25.88 25.69-27.35 64.27-17.87 98a27 27 0 0 1-7.67 27.14l-173 160.76a40.76 40.76 0 1 0 57.57 57.54l162.15-173.3a27 27 0 0 1 26.77-7.7c33.46 8.94 71.49 7.26 97.07-17.94 27.49-27.08 33.42-74.94 20.1-102.33a.85.85 0 0 0-1.36-.22Z" stroke="currentColor" stroke-linecap="round" stroke-miterlimit="10" stroke-width="32px"/><path d="M224 284c-17.48-17-25.49-24.91-31-30.29a18.24 18.24 0 0 1-3.33-21.35 20.8 20.8 0 0 1 3.5-4.62l15.68-15.29a18.7 18.7 0 0 1 5.63-3.87 18.11 18.11 0 0 1 20 3.62c5.45 5.29 15.43 15 33.41 32.52M317.07 291.3c40.95 38.1 90.62 83.27 110 99.41a13.46 13.46 0 0 1 .94 19.92L394.63 444a14 14 0 0 1-20.29-.76c-16.53-19.18-61.09-67.11-99.27-107" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="32px"/><path d="m17.34 193.5 29.41-28.74a4.7 4.7 0 0 1 3.41-1.35 4.85 4.85 0 0 1 3.41 1.35h0a9.86 9.86 0 0 0 8.19 2.77c3.83-.42 7.92-1.6 10.57-4.12 6-5.8-.94-17.23 4.34-24.54a207 207 0 0 1 19.78-22.6c6-5.88 29.84-28.32 69.9-44.45A107.3 107.3 0 0 1 206.67 64c22.59 0 40 10 46.26 15.67a89.5 89.5 0 0 1 10.28 11.64 79 79 0 0 0-9.21-2.77 68.8 68.8 0 0 0-20-1.26c-13.33 1.09-29.41 7.26-38 14-13.9 11-19.87 25.72-20.81 44.71-.68 14.12 2.72 22.1 36.1 55.49a6.6 6.6 0 0 1-.34 9.16l-18.22 18a6.88 6.88 0 0 1-9.54.09c-21.94-21.94-36.65-33.09-45-38.16s-15.07-6.5-18.3-6.85a30.85 30.85 0 0 0-18.27 3.87 11.4 11.4 0 0 0-2.64 2 14.14 14.14 0 0 0 .42 20.08l1.71 1.6a4.63 4.63 0 0 1 0 6.64L71.73 246.6a4.7 4.7 0 0 1-3.41 1.4 4.86 4.86 0 0 1-3.41-1.35l-47.57-46.43a4.88 4.88 0 0 1 0-6.72" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="32px"/></svg>
            </div>
            <h3 class="modulo-nombre">Ingenierías y Ciencias Económicas</h3>
            <span class="modulo-carreras">Ing. de Sistemas · Ing. Civil · Economía</span>
          </div>
          <div class="modulo-row">
            <div class="modulo-icono" style="background:rgba(198,40,40,.16);color:#C62828">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="26" height="26" fill="none" aria-hidden="true"><path d="m429.93 174.27-16.47-28.59a15.49 15.49 0 0 0-21.15-5.7l-98.39 57a4 4 0 0 1-6-3.5L288 80a16 16 0 0 0-16-16h-32a16 16 0 0 0-16 16l.07 113.57a4 4 0 0 1-6 3.5l-98.39-57a15.49 15.49 0 0 0-21.15 5.7l-16.46 28.6a15.42 15.42 0 0 0 5.69 21.1l98.49 57.08a4 4 0 0 1 0 6.9l-98.49 57.08a15.54 15.54 0 0 0-5.69 21.1l16.47 28.59a15.49 15.49 0 0 0 21.15 5.7l98.39-57a4 4 0 0 1 6 3.5L224 432a16 16 0 0 0 16 16h32a16 16 0 0 0 16-16l-.07-113.67a4 4 0 0 1 6-3.5l98.39 57a15.49 15.49 0 0 0 21.15-5.7l16.47-28.59a15.42 15.42 0 0 0-5.69-21.1l-98.49-57.08a4 4 0 0 1 0-6.9l98.49-57.08a15.51 15.51 0 0 0 5.68-21.11" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="32px"/></svg>
            </div>
            <h3 class="modulo-nombre">Ciencias de la Salud</h3>
            <span class="modulo-carreras">Medicina Humana · Enfermería · Obstetricia</span>
          </div>
          <div class="modulo-row">
            <div class="modulo-icono" style="background:rgba(106,27,154,.2);color:#6A1B9A">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="26" height="26" fill="none" aria-hidden="true"><path d="M32 192 256 64l224 128-224 128z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="32px"/><path d="M112 240v128l144 80 144-80V240M480 368V192M256 320v128" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="32px"/></svg>
            </div>
            <h3 class="modulo-nombre">Ciencias Sociales y Educación</h3>
            <span class="modulo-carreras">Derecho · Educación · Sociología</span>
          </div>
          <div class="modulo-row">
            <div class="modulo-icono" style="background:rgba(46,125,50,.16);color:#2E7D32">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="26" height="26" fill="none" aria-hidden="true"><path d="M321.89 171.42C233 114 141 155.22 56 65.22c-19.8-21-8.3 235.5 98.1 332.7 77.79 71 197.9 63.08 238.4-5.92s18.28-163.17-70.61-220.58" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="32px"/><path d="M173 253c86 81 175 129 292 147" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="32px"/></svg>
            </div>
            <h3 class="modulo-nombre">Ciencias Agrarias</h3>
            <span class="modulo-carreras">Agronomía · Ing. Forestal · Zootecnia</span>
          </div>
          <div class="modulo-row modulo-row--last">
            <div class="modulo-icono" style="background:rgba(0,105,92,.2);color:#00695C">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="26" height="26" fill="none" aria-hidden="true"><path d="M176 48h160M118 304h276M208 48v93.48a64.1 64.1 0 0 1-9.88 34.18L73.21 373.49C48.4 412.78 76.63 464 123.08 464h265.84c46.45 0 74.68-51.22 49.87-90.51L313.87 175.66a64.1 64.1 0 0 1-9.87-34.18V48" stroke="currentColor" stroke-linecap="round" stroke-miterlimit="10" stroke-width="32px"/></svg>
            </div>
            <h3 class="modulo-nombre">Ciencias Biológicas</h3>
            <span class="modulo-carreras">Biología · Ing. Ambiental · Microbiología</span>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="cta-final">
      <div class="section-inner">
        <div class="cta-card">
          <svg aria-hidden="true" preserveAspectRatio="xMidYMid slice" viewBox="0 0 920 480" class="cta-svg">
            <g transform="translate(770 64)">
              <circle r="232" style="fill:none;stroke:#f59e0b;stroke-opacity:.07;stroke-width:1;stroke-dasharray:3 6"></circle>
              <circle r="150" style="fill:none;stroke:#f59e0b;stroke-opacity:.12;stroke-width:1.1"></circle>
              <circle r="86" style="fill:none;stroke:#f59e0b;stroke-opacity:.2;stroke-width:1.4"></circle>
            </g>
            <path d="M-40 452 C 200 408 400 320 580 244 S 850 116 1010 60" style="fill:none;stroke:#4A90D9;stroke-opacity:.32;stroke-width:2;stroke-linecap:round;stroke-dasharray:2 10"></path>
            <path d="M-40 480 C 230 432 460 350 640 268 S 880 150 1010 92" style="fill:none;stroke:#ffffff;stroke-opacity:.07;stroke-width:1.3;stroke-linecap:round"></path>
            <circle cx="772" cy="62" r="13" style="fill:#C9A800"></circle>
            <circle cx="44" cy="462" r="10" style="fill:#142040;stroke:#4A90D9;stroke-opacity:.6;stroke-width:2"></circle>
            <circle cx="44" cy="462" r="5" style="fill:#4A90D9"></circle>
          </svg>
          <div class="cta-content">
            <span class="kicker kicker--teal">Tu próximo paso</span>
            <h2 class="cta-h2">Empieza hoy.<br /><span class="cta-muted">Tu examen no espera.</span></h2>
            <p class="cta-desc">Descarga AcademIA y mira tu afinidad subir desde la primera práctica.</p>
            <div class="store-row store-row--center">
              <a href="https://play.google.com/store/apps" class="store-btn store-btn--light">
                <i class="mdi mdi-google-play store-icon"></i>
                <span class="store-text">
                  <small>Disponible en</small>
                  <strong>Google Play</strong>
                </span>
              </a>
              <a href="https://www.apple.com/app-store/" class="store-btn store-btn--outline">
                <i class="mdi mdi-apple store-icon"></i>
                <span class="store-text">
                  <small>Descarga en</small>
                  <strong>App Store</strong>
                </span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
      <div class="footer-top">
        <div class="footer-brand">
          <img src="/academia-logo.svg" alt="AcademIA" width="34" height="34" class="footer-logo" />
          <span class="footer-wordmark">Academ<span class="nav-ia">IA</span></span>
        </div>
