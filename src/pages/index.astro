<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  /* ── Hamburger menu ── */
  (function () {
    const btn = document.getElementById(
      "nav-hamburger",
    ) as HTMLButtonElement | null;
    const mobileNav = document.getElementById("mobile-nav");
    if (!btn || !mobileNav) return;

    btn.addEventListener("click", () => {
      const isOpen = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", String(!isOpen));
      mobileNav.classList.toggle("open", !isOpen);
      mobileNav.setAttribute("aria-hidden", String(isOpen));
    });

    mobileNav.querySelectorAll<HTMLAnchorElement>("a").forEach((link) => {
      link.addEventListener("click", () => {
        btn.setAttribute("aria-expanded", "false");
        mobileNav.classList.remove("open");
        mobileNav.setAttribute("aria-hidden", "true");
      });
    });
  })();

  /* ── Scroll spy ── */
  (function () {
    const links = Array.from(
      document.querySelectorAll<HTMLAnchorElement>(".nav-links a"),
    );
    const sectionToNav: Record<string, string> = {
      features: "#features",
      how: "#how",
      waitlist: "#how",
    };
    const linkByHref = new Map(links.map((l) => [l.getAttribute("href"), l]));
    const sections = Object.keys(sectionToNav)
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);
    if (sections.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const navHref = sectionToNav[entry.target.id];
            links.forEach((l) => l.classList.remove("active"));
            linkByHref.get(navHref)?.classList.add("active");
          }
        });
      },
      { rootMargin: "-40% 0px -55% 0px", threshold: 0 },
    );
    sections.forEach((s) => observer.observe(s));
  })();

  /* ── Waitlist form ── */
  (function () {
    const form = document.getElementById(
      "waitlist-form",
    ) as HTMLFormElement | null;
    const statusEl = document.getElementById("form-status");
    if (!form || !statusEl) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const emailInput = form.querySelector<HTMLInputElement>(
        'input[type="email"]',
      );
      const submitBtn = form.querySelector<HTMLButtonElement>(
        'button[type="submit"]',
      );
      if (!emailInput || !submitBtn) return;

      const email = emailInput.value.trim();
      if (!email) {
        statusEl.textContent = "Por favor ingresa tu correo.";
        statusEl.className = "form-status form-status--error";
        emailInput.focus();
        return;
      }
      submitBtn.disabled = true;
      submitBtn.textContent = "Registrando...";
      statusEl.textContent = "";
      statusEl.className = "form-status";

      /* Reemplazar con integración real (Supabase, ConvertKit, Resend…) */
      await new Promise<void>((resolve) => setTimeout(resolve, 900));

      statusEl.textContent =
        "¡Listo! Te avisamos cuando AcademIA esté disponible.";
      statusEl.className = "form-status form-status--success";
      emailInput.value = "";
      submitBtn.disabled = false;
      submitBtn.textContent = "Registrarme";
    });
  })();

  /* ════════════════════════════════
     GSAP ANIMATIONS
  ════════════════════════════════ */
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!reduced) {
    /* ── 1. Hero entrance timeline ── */
    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

    tl.from(".navbar", { y: -28, opacity: 0, duration: 0.55 }, 0)
      .from(".h1-line-1", { y: 48, opacity: 0, duration: 0.75 }, 0.18)
      .from(".h1-line-2", { y: 48, opacity: 0, duration: 0.75 }, 0.44)
      .from(".lead", { y: 28, opacity: 0, duration: 0.6 }, 0.58)
      .from(
        ".btn-primary",
        { y: 20, opacity: 0, duration: 0.5, scale: 0.94 },
        0.7,
      )
      .from(
        ".hero-stats li",
        { y: 22, opacity: 0, stagger: 0.1, duration: 0.55 },
        0.82,
      )
      .from(
        ".hero-phone-back",
        { y: 70, opacity: 0, duration: 0.95, ease: "power2.out" },
        0.28,
      )
      .from(
        ".hero-phone-front",
        { y: 90, opacity: 0, duration: 1.05, ease: "power2.out" },
        0.42,
      )
      .from(
        ".float-chip",
        {
          scale: 0.4,
          opacity: 0,
          stagger: 0.22,
          duration: 0.65,
          ease: "back.out(1.7)",
        },
        0.88,
      )
      .from(".scroll-hint", { opacity: 0, duration: 0.6 }, 1.3);

    /* ── 2. Counter animation (hero stats) ── */
    document.querySelectorAll<HTMLElement>(".hero-stats b").forEach((el) => {
      const end = parseInt(el.textContent ?? "0");
      const obj = { val: 0 };
      gsap.to(obj, {
        val: end,
        duration: 1.8,
        ease: "power2.out",
        delay: 1.0,
        onUpdate() {
          el.textContent = Math.round(obj.val).toString();
        },
      });
    });

    /* ── 3. Trust bar ── */
    gsap.from(".trust-list li", {
      x: -44,
      opacity: 0,
      stagger: 0.12,
      duration: 0.72,
      scrollTrigger: { trigger: ".trust", start: "top 88%" },
    });

    /* ── 4. Section heads ── */
    gsap.utils.toArray<HTMLElement>(".section-head").forEach((head) => {
      gsap.from(Array.from(head.children), {
        y: 34,
        opacity: 0,
        stagger: 0.1,
        duration: 0.7,
        scrollTrigger: { trigger: head, start: "top 82%" },
      });
    });

    /* ── 5. Feature rows: slide desde lados opuestos ── */
    gsap.utils.toArray<HTMLElement>(".feature-row").forEach((row) => {
      const isReverse = row.classList.contains("feature-row--reverse");
      const text = row.querySelector(".feature-text");
      const media = row.querySelector(".feature-media");

      gsap.from(text, {
        x: isReverse ? 64 : -64,
        opacity: 0,
        duration: 0.85,
        scrollTrigger: { trigger: row, start: "top 78%" },
      });
      gsap.from(media, {
        x: isReverse ? -64 : 64,
        opacity: 0,
        duration: 0.85,
        delay: 0.1,
        scrollTrigger: { trigger: row, start: "top 78%" },
      });
      gsap.from(row.querySelectorAll(".ticks li"), {
        x: -20,
        opacity: 0,
        stagger: 0.08,
        duration: 0.5,
        scrollTrigger: { trigger: row, start: "top 65%" },
      });
    });

    /* ── 6. How steps: stagger desde abajo ── */
    gsap.from(".how-step", {
      y: 64,
      opacity: 0,
      stagger: 0.2,
      duration: 0.85,
      scrollTrigger: { trigger: ".how-grid", start: "top 74%" },
    });

    /* Conector: dibujarse de izquierda a derecha */
    gsap.from(".how-connector", {
      scaleX: 0,
      transformOrigin: "left center",
      duration: 1.2,
      ease: "power2.inOut",
      scrollTrigger: { trigger: ".how-grid", start: "top 62%" },
    });

    /* ── 7. Waitlist card: emerge desde abajo ── */
    gsap.from(".waitlist-card", {
      y: 56,
      opacity: 0,
      scale: 0.96,
      duration: 0.9,
      ease: "power3.out",
      scrollTrigger: { trigger: ".waitlist", start: "top 82%" },
    });
  }
</script>
