<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  /* ── Gauge: animar arcos SVG al entrar en vista ── */
  const C = 2 * Math.PI * 80;
  const gaugeObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      entry.target.querySelectorAll<SVGCircleElement>('.gauge-arc').forEach(arc => {
        const pct = parseFloat(arc.dataset.pct ?? '0');
        arc.style.strokeDashoffset = String(C * (1 - pct / 100));
      });
      gaugeObs.unobserve(entry.target);
    });
  }, { threshold: 0.2 });
  const gaugeGrid = document.getElementById('gauge-grid');
  if (gaugeGrid) gaugeObs.observe(gaugeGrid);

  /* ── Scroll spy: ilumina el nav link de la sección visible ── */
  const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.nav-links a'));
  const sectionIds = ['como', 'features', 'modulos'];
  const sections = sectionIds.map(id => document.getElementById(id)).filter(Boolean) as HTMLElement[];

  const spyObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      navLinks.forEach(l => l.classList.remove('active'));
      const match = navLinks.find(l => l.getAttribute('href') === `#${entry.target.id}`);
      match?.classList.add('active');
    });
  }, { rootMargin: '-40% 0px -55% 0px', threshold: 0 });
  sections.forEach(s => spyObs.observe(s));

  /* ── GSAP: sin animaciones si prefiere movimiento reducido ── */
  if (!reduced) {
    /* 1. Hero entrada */
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    tl.from('#navbar',       { y: -32, opacity: 0, duration: 0.5 }, 0)
      .from('.hero-label',   { y: 36, opacity: 0, duration: 0.6 }, 0.2)
      .from('h1',            { y: 44, opacity: 0, duration: 0.75 }, 0.35)
      .from('.hero-lead',    { y: 28, opacity: 0, duration: 0.6 }, 0.52)
      .from('.store-row',    { y: 22, opacity: 0, duration: 0.55 }, 0.64)
      .from('.hero-footnote',{ y: 16, opacity: 0, duration: 0.5 }, 0.72)
      .from('.phone-wrap',   { y: 70, opacity: 0, duration: 1.0, ease: 'power2.out' }, 0.28);

    /* 2. Secciones: tarjetas stagger desde abajo */
    const staggerGroups = [
      { targets: '.problema-card',  trigger: '.problema-grid' },
      { targets: '.como-card',      trigger: '.como-grid' },
      { targets: '.feature-card',   trigger: '.features-grid' },
      { targets: '.gauge-card',     trigger: '.gauge-grid' },
      { targets: '.modulo-row',     trigger: '.modulos-table' },
    ];
    staggerGroups.forEach(({ targets, trigger }) => {
      gsap.from(targets, {
        y: 48, opacity: 0, stagger: 0.1, duration: 0.7,
        scrollTrigger: { trigger, start: 'top 80%' },
      });
    });

    /* 3. Títulos de sección */
    document.querySelectorAll<HTMLElement>('.section-head').forEach(head => {
      gsap.from(Array.from(head.children), {
        y: 30, opacity: 0, stagger: 0.1, duration: 0.65,
        scrollTrigger: { trigger: head, start: 'top 82%' },
      });
    });

    /* 4. CTA final */
    gsap.from('.cta-card', {
      y: 56, opacity: 0, scale: 0.97, duration: 0.9, ease: 'power3.out',
      scrollTrigger: { trigger: '.cta-card', start: 'top 82%' },
    });
  }
</script>
