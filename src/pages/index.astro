---
import Layout from "../layouts/Layout.astro";
import PhoneDemo from "../components/PhoneDemo.astro";
import Phone from "../components/Phone.astro";

import screenHome from "../assets/screens/screen-home.png";
import screenSimulacro from "../assets/screens/screen-simulacro.png";
import screenPlanEstudio from "../assets/screens/screen-plan-estudio.png";
import screenMatchCarrera from "../assets/screens/screen-match-carrera.png";
import screenPracticaAdaptativa from "../assets/screens/screen-practica-adaptativa.png";
import screenProgresoMarkov from "../assets/screens/screen-progreso-markov.png";
import screenResultados from "../assets/screens/screen-resultados.png";
---

<Layout>
  <!-- ═══ NAVBAR ═══ -->
  <header class="navbar" id="navbar">
    <div class="nav-inner">
      <a href="/" class="brand" aria-label="AcademIA — inicio">
        <span class="brand-icon">
          <svg
            width="17"
            height="17"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <circle cx="5" cy="19" r="2" fill="#fff"></circle>
            <circle cx="19" cy="5" r="2.6" fill="#F5A623"></circle>
            <line x1="6" y1="18" x2="17" y2="7" stroke="#fff" stroke-width="1.6"
            ></line>
          </svg>
        </span>
        <span class="brand-name">AcademIA</span>
      </a>

      <nav class="nav-links" id="nav-links" aria-label="Secciones">
        <a href="#features">Por qué AcademIA</a>
        <a href="#how">Cómo funciona</a>
      </nav>

      <a href="#waitlist" class="btn-pill">Registrarme</a>

      <button
        class="nav-hamburger"
        id="nav-hamburger"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span></span><span></span><span></span>
      </button>
    </div>

    <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
      <a href="#features" class="mobile-link">Por qué AcademIA</a>
      <a href="#how" class="mobile-link">Cómo funciona</a>
      <a href="#waitlist" class="mobile-link mobile-link--cta"
        >Registrarme gratis</a
      >
    </div>
  </header>

  <main id="content" tabindex="-1">
    <!-- ═══ HERO (DARK) ═══ -->
    <section class="hero">
      <div class="hero-bg" aria-hidden="true"></div>

      <div class="hero-inner">
        <div class="hero-copy">
          <h1>
            <span class="h1-line-1">La app que sabe</span>
            <em class="h1-line-2">qué estudiar después.</em>
          </h1>

          <p class="lead">
            Practica con exámenes reales de admisión a la UNC, recibe un plan
            personalizado después de cada simulacro y descubre, en cinco
            preguntas, qué tan cerca estás de tu carrera.
          </p>

          <div class="cta-row">
            <a href="#waitlist" class="btn-primary">Quiero ser el primero</a>
          </div>

          <ul class="hero-stats">
            <li><b>90</b><span>preguntas por examen</span></li>
            <li><b>30</b><span>exámenes oficiales</span></li>
            <li><b>28</b><span>carreras mapeadas</span></li>
          </ul>
        </div>

        <div class="hero-stage">
          <div class="hero-phone-back" aria-hidden="true">
            <Phone src={screenProgresoMarkov} alt="" size="sm" fetchpriority="low" />
          </div>
          <div class="hero-phone-front">
            <PhoneDemo />
            <span class="float-chip chip-top">
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#15A98C"
                stroke-width="2.4"
                aria-hidden="true"
                ><circle cx="12" cy="12" r="9"></circle><path d="M9 12l2 2 4-4"
                ></path></svg
              >
              Exámenes reales UNC
            </span>
            <span class="float-chip chip-bottom">
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#F5A623"
                stroke-width="2.4"
                aria-hidden="true"
                ><path
                  d="M12 2l2.6 6.6L21 11l-6.4 2.4L12 20l-2.6-6.6L3 11l6.4-2.4z"
                ></path></svg
              >
              Match de carrera
            </span>
          </div>
        </div>
      </div>

      <!-- scroll hint -->
      <div class="scroll-hint" aria-hidden="true">
        <svg class="scroll-chevron" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.42)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 9l6 6 6-6"/>
        </svg>
      </div>
    </section>

    <!-- ═══ TRUST BAR ═══ -->
    <section class="trust" aria-label="Características clave">
      <div class="trust-grid">
        <div class="trust-card">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z" stroke="#F5A623" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M6 12v5c3.33 2 8.67 2 12 0v-5" stroke="#F5A623" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <div class="trust-card-body">
            <strong>Exclusiva para la UNC</strong>
            <span>Diseñada para postulantes de la UNC Cajamarca</span>
          </div>
        </div>
        <div class="trust-card">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" stroke="#15A98C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <rect x="9" y="3" width="6" height="4" rx="1" stroke="#15A98C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M9 12l2 2 4-4" stroke="#15A98C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <div class="trust-card-body">
            <strong>Exámenes oficiales</strong>
            <span>Basada en pruebas reales 2023–2026</span>
          </div>
        </div>
        <div class="trust-card">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="3" stroke="#F5A623" stroke-width="2"/>
            <path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12" stroke="#F5A623" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <div class="trust-card-body">
            <strong>Plan personalizado</strong>
            <span>Plan de estudio que se ajusta a ti</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ FEATURES ═══ -->
    <section class="features" id="features">
      <div class="section-head">
        <span class="kicker">Por qué AcademIA</span>
        <h2>No es una app de práctica más.</h2>
        <p>
          Cada parte está pensada para cómo funciona realmente el ingreso a la
          UNC.
        </p>
      </div>

      <div class="feature-row">
        <div class="feature-text">
          <span class="feature-num">01</span>
          <h3>Simulacros reales de la UNC</h3>
          <p>
            Resuelve exámenes tal como son: 90 preguntas, módulos A a E,
            períodos reales. El mismo formato, la misma estructura y la misma
            dificultad que el día del examen.
          </p>
          <ul class="ticks">
            <li>Preguntas extraídas de exámenes oficiales</li>
            <li>Cronómetro y puntaje como en la prueba real</li>
            <li>Revisa cada examen pregunta por pregunta</li>
          </ul>
        </div>
        <div class="feature-media">
          <div class="media-phone">
            <Phone
              src={screenSimulacro}
              alt="Pregunta de simulacro de razonamiento matemático"
            />
          </div>
          <div class="callout callout-a">
            <span class="callout-label">Examen UNC 2026-I</span>
            <span class="callout-value">90 preguntas · 180 min</span>
          </div>
        </div>
      </div>

      <div class="feature-row feature-row--reverse">
        <div class="feature-text">
          <span class="feature-num">02</span>
          <h3>Un plan que aprende de ti</h3>
          <p>
            AcademIA detecta tus temas débiles y arma tu plan de la semana: qué
            estudiar, cuántas preguntas y por qué. Cambia a medida que avanzas y
            según los días que faltan.
          </p>
          <ul class="ticks">
            <li>Identifica tus puntos críticos automáticamente</li>
            <li>Agenda semanal con prioridades por tema</li>
            <li>Recomendaciones después de cada simulacro</li>
          </ul>
        </div>
        <div class="feature-media">
          <div class="media-phone media-phone--tilt-left">
            <Phone
              src={screenPlanEstudio}
              alt="Plan de estudio personalizado con agenda semanal"
            />
          </div>
          <div class="callout callout-b">
            <span class="callout-label">Agenda de esta semana</span>
            <span class="callout-value">Álgebra · 15 preguntas hoy</span>
          </div>
        </div>
      </div>

      <div class="feature-row">
        <div class="feature-text">
          <span class="feature-num">03</span>
          <h3>Tu carrera, con datos</h3>
          <p>
            Responde cinco preguntas sobre tus intereses y obtén tu porcentaje
            de afinidad con cada una de las 28 carreras de la UNC. Decide con
            información, no con corazonadas.
          </p>
          <ul class="ticks">
            <li>Test de afinidad en cinco preguntas</li>
            <li>Ranking de carreras más afines a ti</li>
            <li>Descripción, salidas y temas clave de cada carrera</li>
          </ul>
        </div>
        <div class="feature-media">
          <div class="media-phone">
            <Phone
              src={screenMatchCarrera}
              alt="Resultado del test de afinidad de carrera"
            />
          </div>
          <div class="callout callout-c">
            <span class="callout-label">Tu mejor match</span>
            <span class="callout-value">Ing. Hidráulica · 67% afín</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ CÓMO FUNCIONA ═══ -->
    <section class="how" id="how">
      <div class="section-head section-head--center">
        <span class="kicker">El proceso</span>
        <h2>Tres pasos que se retroalimentan.</h2>
        <p>
          Cada sesión alimenta la siguiente. Así es como AcademIA aprende
          contigo.
        </p>
      </div>

      <div class="how-grid">
        <div class="how-connector" aria-hidden="true">
          <svg
            width="100%"
            height="4"
            preserveAspectRatio="none"
            focusable="false"
          >
            <defs>
              <linearGradient id="stepGrad" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#15A98C"></stop>
                <stop offset="100%" stop-color="#F5A623"></stop>
              </linearGradient>
            </defs>
            <rect width="100%" height="4" fill="url(#stepGrad)" rx="2"></rect>
          </svg>
        </div>

        <article class="how-step">
          <div class="how-phone">
            <Phone
              src={screenPracticaAdaptativa}
              alt="Pantalla de práctica diaria con sesión adaptativa"
            />
          </div>
          <div class="how-step-body">
            <span class="step-badge">1</span>
            <h3>Practica</h3>
            <p>
              Sesiones diarias o simulacros completos. Cada respuesta alimenta
              tu perfil.
            </p>
          </div>
        </article>

        <article class="how-step">
          <div class="how-phone">
            <Phone src={screenResultados} alt="Resultados con diagnóstico de áreas" />
          </div>
          <div class="how-step-body">
            <span class="step-badge">2</span>
            <h3>El sistema aprende</h3>
            <p>
              La app identifica tus áreas críticas y actualiza tu probabilidad
              de ingreso.
            </p>
          </div>
        </article>

        <article class="how-step">
          <div class="how-phone">
            <Phone src={screenPlanEstudio} alt="Agenda semanal personalizada" />
          </div>
          <div class="how-step-body">
            <span class="step-badge">3</span>
            <h3>Recibe tu plan</h3>
            <p>
              AcademIA te dice qué estudiar mañana, con qué prioridad y por
              cuánto tiempo.
            </p>
          </div>
        </article>
      </div>
    </section>

    <!-- ═══ LISTA DE ESPERA ═══ -->
    <section class="waitlist" id="waitlist">
      <div class="waitlist-card">
        <div class="waitlist-glow" aria-hidden="true"></div>

        <div class="waitlist-copy">
          <span class="kicker kicker--gold">Próximamente</span>
          <h2 class="waitlist-title">Sé el primero en acceder.</h2>
          <p class="waitlist-desc">
            AcademIA abre muy pronto. Deja tu correo y te avisamos en el momento
            del lanzamiento, sin spam.
          </p>

          <form class="waitlist-form" id="waitlist-form" novalidate>
            <div class="form-row">
              <label for="waitlist-email" class="sr-only"
                >Correo electrónico</label
              >
              <input
                type="email"
                id="waitlist-email"
                name="email"
                placeholder="tucorreo@gmail.com"
                autocomplete="email"
                required
              />
              <button type="submit" class="btn-submit">Registrarme</button>
            </div>
            <p
              class="form-status"
              id="form-status"
              aria-live="polite"
              aria-atomic="true"
            >
            </p>
          </form>

          <div class="store-soon">
            <span class="store-badge">
              <svg
                width="19"
                height="19"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
                ><path
                  d="M16.4 12.7c0-2 1.6-3 1.7-3a3.7 3.7 0 0 0-2.9-1.6c-1.2-.1-2.4.7-3 .7s-1.6-.7-2.6-.7a3.9 3.9 0 0 0-3.3 2c-1.4 2.5-.4 6.2 1 8.2.7 1 1.5 2.1 2.5 2 1-.04 1.4-.65 2.6-.65s1.6.65 2.6.63c1.1-.02 1.8-1 2.4-2a9 9 0 0 0 1.1-2.2c-.02-.01-2.1-.82-2.1-3.18zM14.5 6.3a3.5 3.5 0 0 0 .8-2.5 3.6 3.6 0 0 0-2.3 1.2 3.3 3.3 0 0 0-.8 2.4 3 3 0 0 0 2.3-1.1z"
                ></path></svg
              >
              <span
                ><small>Próximamente en</small><strong>App Store</strong></span
              >
            </span>
            <span class="store-badge">
              <svg
                width="19"
                height="19"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
                ><path
                  d="M4 3.5 13.5 12 4 20.5c-.3-.2-.5-.6-.5-1V4.5c0-.4.2-.8.5-1zm10.8 9.2 2.6 2.4-9.2 5.2 6.6-7.6zm0-1.4L8.2 3.7l9.2 5.2-2.6 2.4zM17.9 9.7l2.6 1.5c.5.3.5 1.3 0 1.6l-2.6 1.5-2.8-2.3 2.8-2.3z"
                ></path></svg
              >
              <span
                ><small>Próximamente en</small><strong>Google Play</strong
                ></span
              >
            </span>
          </div>
        </div>

        <div class="waitlist-phone" aria-hidden="true">
          <Phone src={screenHome} alt="" size="sm" />
        </div>
      </div>
    </section>
  </main>

  <!-- ═══ FOOTER ═══ -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="brand-icon brand-icon--sm">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <circle cx="5" cy="19" r="2" fill="#fff"></circle>
            <circle cx="19" cy="5" r="2.6" fill="#F5A623"></circle>
            <line x1="6" y1="18" x2="17" y2="7" stroke="#fff" stroke-width="1.6"
            ></line>
          </svg>
        </span>
        <span>AcademIA</span>
      </div>
      <nav class="footer-links" aria-label="Páginas legales">
        <a href="/privacy-policy">Política de privacidad</a>
        <a href="/terms-of-use">Términos de uso</a>
        <a href="/delete-account">Eliminar cuenta</a>
      </nav>
      <p class="footer-copy">
        &copy; AcademIA 2026 &middot; Preparación admisión UNC, Cajamarca, Perú
      </p>
    </div>
  </footer>
</Layout>

<style>
  /* ═══════════════════════════════════
   NAVBAR
═══════════════════════════════════ */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(6, 9, 15, 0.82);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    transition:
      background 0.3s ease,
      border-color 0.3s ease;
  }
  .navbar.scrolled {
    background: rgba(6, 9, 15, 0.95);
  }
  .nav-inner {
    max-width: 1080px;
    margin: 0 auto;
    height: 66px;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 9px;
    font-weight: 800;
    font-size: var(--text-md);
    color: #fff;
    letter-spacing: -0.01em;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .brand-icon {
    width: 32px;
    height: 32px;
    border-radius: 9px;
    background: linear-gradient(145deg, var(--navy), var(--navy-deep));
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }
  .nav-links {
    display: flex;
    gap: 28px;
    margin: 0 auto;
  }
  .nav-links a {
    position: relative;
    font-size: var(--text-base);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .nav-links a:hover {
    color: #fff;
  }
  .nav-links a.active {
    color: #fff;
  }
  .nav-links a.active::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -6px;
    height: 2px;
    background: var(--gold);
    border-radius: 2px;
  }
  .btn-pill {
    background: var(--gold);
    color: var(--navy-deep);
    font-size: var(--text-sm);
    font-weight: 800;
    padding: 10px 20px;
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
    transition:
      transform 0.16s ease,
      box-shadow 0.16s ease;
    box-shadow: 0 4px 18px -6px rgba(245, 166, 35, 0.45);
  }
  .btn-pill:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 24px -6px rgba(245, 166, 35, 0.55);
  }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 38px;
    height: 38px;
    background: none;
    border: 1.5px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    cursor: pointer;
    padding: 0;
    margin-left: auto;
    transition: border-color 0.16s;
  }
  .nav-hamburger span {
    display: block;
    width: 18px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition:
      transform 0.22s ease,
      opacity 0.22s ease;
  }
  .nav-hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .nav-hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile nav */
  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 8px 24px 16px;
    background: rgba(6, 9, 15, 0.96);
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }
  .mobile-nav.open {
    display: flex;
  }
  .mobile-link {
    font-size: var(--text-md);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.75);
    padding: 14px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    text-decoration: none;
    transition: color 0.16s;
  }
  .mobile-link:last-child {
    border-bottom: none;
  }
  .mobile-link:hover {
    color: var(--teal);
  }
  .mobile-link--cta {
    color: var(--gold);
    font-weight: 800;
    padding-top: 18px;
  }

  @media (max-width: 720px) {
    .nav-links {
      display: none;
    }
    .btn-pill {
      display: none;
    }
    .nav-hamburger {
      display: flex;
    }
  }

  /* ═══════════════════════════════════
   HERO — DARK FULL-HEIGHT
═══════════════════════════════════ */
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding: 100px 24px 80px;
    background: #06090f;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(
        55% 65% at 15% 55%,
        rgba(21, 169, 140, 0.14),
        transparent 70%
      ),
      radial-gradient(
        45% 55% at 85% 25%,
        rgba(27, 61, 110, 0.32),
        transparent 70%
      ),
      radial-gradient(
        30% 40% at 60% 90%,
        rgba(245, 166, 35, 0.07),
        transparent 70%
      );
    animation: hero-breathe 14s ease-in-out infinite;
  }
  @keyframes hero-breathe {
    0%,
    100% {
      opacity: 0.75;
    }
    50% {
      opacity: 1;
    }
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1080px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 48px;
    align-items: center;
  }

  /* H1 — large, warm white */
