---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Restablecer contraseña — AcademIA"
  description="Restablece tu contraseña de AcademIA."
>
  <div class="page">
    <div class="page-container">
      <h1>Restablecer contraseña</h1>
      <div id="form-wrap">
        <p class="hint">Procesando enlace de restablecimiento...</p>
      </div>
    </div>
  </div>
</Layout>

<!-- Lógica Supabase: lee el hash de la URL y presenta el formulario de nueva contraseña -->
<script>
  (function () {
    var hash = window.location.hash.slice(1);
    var params = new URLSearchParams(hash);
    var accessToken = params.get("access_token");
    var wrap = document.getElementById("form-wrap");

    if (!accessToken || !wrap) {
      if (wrap)
        wrap.innerHTML =
          '<p class="error">Enlace inválido o expirado. Solicita un nuevo correo de restablecimiento desde la app.</p>';
      return;
    }

    wrap.innerHTML = `
      <form id="reset-form">
        <label for="password">Nueva contraseña</label>
        <input id="password" type="password" placeholder="Mínimo 8 caracteres" minlength="8" required />
        <label for="confirm">Confirmar contraseña</label>
        <input id="confirm" type="password" placeholder="Repite la contraseña" minlength="8" required />
        <button type="submit">Guardar contraseña</button>
        <p id="msg" class="msg"></p>
      </form>
    `;

    document
      .getElementById("reset-form")
      ?.addEventListener("submit", async function (e) {
        e.preventDefault();
        var pw = (document.getElementById("password") as HTMLInputElement)
          .value;
        var co = (document.getElementById("confirm") as HTMLInputElement).value;
        var msg = document.getElementById("msg")!;

        if (pw !== co) {
          msg.textContent = "Las contraseñas no coinciden.";
          msg.className = "msg error";
          return;
        }

        msg.textContent = "Guardando...";
        msg.className = "msg";

        try {
          var res = await fetch("https://YOUR_SUPABASE_URL/auth/v1/user", {
            method: "PUT",
            headers: {
              "Content-Type": "application/json",
              Authorization: "Bearer " + accessToken,
              apikey: "YOUR_SUPABASE_ANON_KEY",
            },
            body: JSON.stringify({ password: pw }),
          });

          if (res.ok) {
            msg.textContent =
              "Contraseña actualizada. Ya puedes iniciar sesión en la app.";
            msg.className = "msg success";
            (document.getElementById("reset-form") as HTMLFormElement).reset();
          } else {
            var data = await res.json();
            msg.textContent =
              data?.msg || "Error al actualizar. Intenta nuevamente.";
            msg.className = "msg error";
          }
        } catch {
          msg.textContent = "Error de conexión. Verifica tu internet.";
          msg.className = "msg error";
        }
      });
  })();
</script>

<style>
  .page {
    min-height: 100vh;
    padding: 80px 24px;
    display: flex;
    align-items: center;
  }
  .page-container {
    max-width: 440px;
    margin: 0 auto;
    width: 100%;
  }
  h1 {
    font-size: 28px;
    font-weight: 800;
    color: var(--navy-deep);
    margin-bottom: 24px;
  }
  .hint {
    color: var(--muted);
    font-size: 15px;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  label {
    font-size: 13.5px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: -6px;
  }
  input {
    width: 100%;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: 13px 14px;
    font-size: 15px;
    color: var(--ink);
    background: #fff;
    font-family: inherit;
    outline: none;
    transition: border-color 0.18s ease;
  }
  input:focus {
    border-color: var(--navy);
  }
  button {
    margin-top: 6px;
    background: var(--navy);
    color: #fff;
    border: none;
    border-radius: 12px;
    padding: 14px;
    font-size: 15px;
    font-weight: 700;
    font-family: inherit;
    transition: opacity 0.18s ease;
  }
  button:hover {
    opacity: 0.88;
  }
  .msg {
    font-size: 13.5px;
    margin-top: 4px;
    min-height: 20px;
  }
  .msg.error {
    color: #c0392b;
  }
  .msg.success {
    color: var(--green);
  }
  .error {
    color: #c0392b;
    font-size: 15px;
  }
</style>
